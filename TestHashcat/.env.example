# Public URL để bạn mở WebUI từ PC1.
# Đổi REMOTE_PUBLIC_IP thành public IP hoặc domain của remote PC.
HTP_PUBLIC_URL=http://REMOTE_PUBLIC_IP:8080

# Admin mặc định, nên đổi sau khi login.
HASHTOPOLIS_ADMIN_USER=admin
HASHTOPOLIS_ADMIN_PASSWORD=ChangeThisStrongPassword

# Database.
MYSQL_ROOT_PASSWORD=ChangeThisRootPassword
MYSQL_DATABASE=hashtopolis
MYSQL_USER=hashtopolis
MYSQL_PASSWORD=ChangeThisDbPassword

# Agent registration.
# Ban đầu để trống. Sau khi mở WebUI và tạo voucher, điền vào rồi start agent.
HTP_VOUCHER=

# Agent nội bộ gọi server qua proxy trong Docker network.
HTP_AGENT_API_URL=http://hashtopolis-proxy/api/server.php

# GPU.
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
